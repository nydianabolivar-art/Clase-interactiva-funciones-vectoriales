// ---- QUIZ ----
let answers = {};
let scores = 0;

function checkQ(qNum, chosen, correct) {
  if(answers[qNum]) return;
  answers[qNum] = chosen;
  const card = document.getElementById('q'+qNum);
  const opts = card.querySelectorAll('.quiz-opt');
  opts.forEach(o => o.classList.add('disabled'));

  const labels = ['a','b','c','d'];
  opts.forEach((o,i) => {
    if(labels[i] === correct) o.classList.add('correct');
    else if(labels[i] === chosen) o.classList.add('wrong');
  });

  const isCorrect = chosen === correct;
  if(isCorrect) scores++;

  // Special handling for Q1 (ambiguous answer)
  if(qNum===1) {
    if(chosen==='a'||chosen==='b') {
      document.getElementById('q1-correct2').classList.add('show');
    } else {
      document.getElementById('q1-wrong').classList.add('show');
    }
  } else {
    const fb = document.getElementById('q'+qNum+(isCorrect?'-correct':'-wrong'));
    if(fb) fb.classList.add('show');
  }

  // Show score when all answered
  if(Object.keys(answers).length >= 5) {
    const scoreEl = document.getElementById('quiz-score');
    scoreEl.style.display = 'block';
    document.getElementById('score-display').textContent = scores+'/5';
    const msgs = {
