<script>
// ---- TAB NAVIGATION ----
function showTab(idx, btn) {
  document.querySelectorAll('.section').forEach((s,i) => s.classList.toggle('active', i===idx));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const pct = ((idx+1)/6*100).toFixed(0);
  document.getElementById('prog-fill').style.width = pct+'%';
  document.getElementById('prog-text').textContent = `Sección ${idx+1} de 6`;
  window.scrollTo({top:0, behavior:'smooth'});
  if(idx===1) { calcDerivative(); }
  if(idx===2) { calcTangentPlane(); }
}

// ---- STEPPER ----
const stepData = { 1: {max:4, prefix:'s1p'}, 2: {max:4, prefix:'s2p'} };
function goStep(group, num) {
  const d = stepData[group];
  for(let i=1;i<=d.max;i++){
    const panel = document.getElementById(d.prefix+i);
    if(panel) panel.classList.toggle('active', i===num);
  }
  const indId = 'step-ind-'+group;
  const inds = document.querySelectorAll('#'+indId+' .step-dot');
  inds.forEach((dot,i) => {
    dot.classList.remove('active','done');
    if(i+1 === num) dot.classList.add('active');
    else if(i+1 < num) dot.classList.add('done');
  });
}

// ---- HELIX CANVAS ----
function drawHelix() {
  const c = document.getElementById('canvas-helix');
  if(!c) return;
  const ctx = c.getContext('2d');
  const W=c.width, H=c.height;
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle='#f1f3f9'; ctx.fillRect(0,0,W,H);

  const cx=W/2, cy=H/2;
  const pts = [];
  for(let t=0; t<=6*Math.PI; t+=0.05) {
    const x = cx + 80*Math.cos(t);
    const y = cy + 80*Math.sin(t)*0.35 - t*6;
    pts.push({x,y,t});
  }

  // Draw helix
  for(let i=1;i<pts.length;i++){
    const ratio = i/pts.length;
    ctx.beginPath();
    ctx.strokeStyle = `rgba(59,95,226,${0.25+ratio*0.75})`;
    ctx.lineWidth = 2;
    ctx.moveTo(pts[i-1].x, pts[i-1].y+H*0.35);
    ctx.lineTo(pts[i].x, pts[i].y+H*0.35);
    ctx.stroke();
  }

  // Labels
  ctx.fillStyle='rgba(74,82,112,0.9)'; ctx.font='11px IBM Plex Mono,monospace'; ctx.textAlign='center';
  ctx.fillText('r(t) = ⟨cos(t), sin(t), t⟩', cx, H-10);
}

// ---- DERIVATIVE CALCULATOR ----
function calcDerivative() {
  const comps = ['dx1','dx2','dx3'].map(id => document.getElementById(id)?.value || '');
  const tVal = parseFloat(document.getElementById('eval-t')?.value) || 0;
  const names = ['x','y','z'];
  let derivs = [];

  try {
    for(const c of comps){
      const expr = math.parse(c);
      const d = math.derivative(expr, 't').toString();
      derivs.push(d);
    }
    document.getElementById('deriv-result').innerHTML =
      `<span style="color:var(--text3);font-size:11px;font-family:var(--sans)">r'(t) =</span><br>` +
      derivs.map((d,i)=>`${names[i]}: ${d}`).join('<br>');

    // Evaluate magnitude
    let sumSq = 0;
    for(const d of derivs) {
      const fn = math.compile(d);
      const val = fn.evaluate({t: tVal});
      sumSq += val*val;
    }
    const mag = Math.sqrt(sumSq);
    document.getElementById('deriv-eval').innerHTML =
      `<span style="color:var(--text3);font-size:11px;font-family:var(--sans)">t = ${tVal}</span><br>` +
      `|r'(${tVal})| = ${mag.toFixed(4)}`;
  } catch(e) {
    document.getElementById('deriv-result').textContent = 'Revisa la sintaxis...';
    document.getElementById('deriv-eval').textContent = '—';
  }
}

// ---- TANGENT PLANE CALCULATOR ----
function calcTangentPlane() {
  const fStr = document.getElementById('tp-func')?.value || 'x^2+y^2';
  const x0 = parseFloat(document.getElementById('tp-x0')?.value) || 1;
  const y0 = parseFloat(document.getElementById('tp-y0')?.value) || 1;

  try {
    const expr = math.parse(fStr);
    const scope0 = {x: x0, y: y0};
    const z0 = math.evaluate(fStr, scope0);
    const dfdx = math.derivative(expr, 'x');
    const dfdy = math.derivative(expr, 'y');
    const fx = dfdx.evaluate(scope0);
    const fy = dfdy.evaluate(scope0);

    document.getElementById('tp-point').innerHTML =
      `P = (${x0}, ${y0}, ${z0.toFixed(4)})`;

    const cStr = (z0 - fx*x0 - fy*y0).toFixed(4);
    document.getElementById('tp-result').innerHTML =
      `z = ${fx.toFixed(4)}(x) + ${fy.toFixed(4)}(y) + ${cStr}\n\n` +
      `fₓ(${x0},${y0}) = ${fx.toFixed(4)}\n` +
      `f_y(${x0},${y0}) = ${fy.toFixed(4)}`;

    document.getElementById('tp-steps').innerHTML =
      `Pasos: 1) z₀ = f(${x0},${y0}) = ${z0.toFixed(3)} · 2) fₓ = ${fx.toFixed(3)}, f_y = ${fy.toFixed(3)} · 3) z−${z0.toFixed(2)} = ${fx.toFixed(2)}(x−${x0}) + ${fy.toFixed(2)}(y−${y0})`;

    drawTangentPlane(fStr, x0, y0, z0, fx, fy);
  } catch(e) {
    document.getElementById('tp-result').textContent = 'Error. Verifica f(x,y). Usa: x^2, sin(x), exp(x)';
  }
}

// ---- TANGENT PLANE CANVAS ----
function drawTangentPlane(fStr, x0, y0, z0, fx, fy) {
  const c = document.getElementById('canvas-tangent');
  if(!c) return;
  const ctx = c.getContext('2d');
  const W=c.width, H=c.height;
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle='#f1f3f9'; ctx.fillRect(0,0,W,H);

  // Simple 3D isometric projection
  function proj3d(x,y,z) {
    const scale = 18;
    const ox = W/2, oy = H/2+20;
    const px = ox + (x-y)*Math.cos(0.4)*scale;
    const py = oy + (x+y)*Math.sin(0.3)*scale - z*0.6*scale;
    return {px, py};
  }

  const range = 2.5, steps = 18;
  const step = range*2/steps;

  // Draw surface
  for(let i=0; i<steps; i++){
    for(let j=0; j<steps; j++){
      const x = x0 - range + i*step;
      const y = y0 - range + j*step;
      const x2 = x+step, y2 = y+step;
      let z;
      try { z = math.evaluate(fStr, {x,y}); } catch(e){ continue; }
      if(Math.abs(z) > 20) continue;
      const p1 = proj3d(x-x0, y-y0, z-z0);
      const p2 = proj3d(x2-x0, y-y0, math.evaluate(fStr,{x:x2,y})-z0);
      const p3 = proj3d(x2-x0, y2-y0, math.evaluate(fStr,{x:x2,y:y2})-z0);
      const p4 = proj3d(x-x0, y2-y0, math.evaluate(fStr,{x,y:y2})-z0);

      ctx.beginPath();
      ctx.moveTo(p1.px,p1.py); ctx.lineTo(p2.px,p2.py);
      ctx.lineTo(p3.px,p3.py); ctx.lineTo(p4.px,p4.py);
      ctx.closePath();
      ctx.fillStyle='rgba(59,95,226,0.06)';
      ctx.strokeStyle='rgba(59,95,226,0.25)';
      ctx.lineWidth=0.5;
      ctx.fill(); ctx.stroke();
    }
  }

  // Draw tangent plane (flat plane)
  const pr = 2;
  const corners = [[-pr,-pr],[pr,-pr],[pr,pr],[-pr,pr]];
  ctx.beginPath();
  corners.forEach(([dx,dy],i) => {
    const dz = fx*dx + fy*dy;
    const p = proj3d(dx, dy, dz);
    if(i===0) ctx.moveTo(p.px,p.py);
    else ctx.lineTo(p.px,p.py);
  });
  ctx.closePath();
  ctx.fillStyle='rgba(13,148,136,0.1)';
  ctx.strokeStyle='rgba(13,148,136,0.7)';
  ctx.lineWidth=1.5;
  ctx.fill(); ctx.stroke();

  // Point of tangency
  const pt = proj3d(0,0,0);
  ctx.beginPath();
  ctx.arc(pt.px, pt.py, 5, 0, Math.PI*2);
  ctx.fillStyle='var(--amber)';
  ctx.fill();

  ctx.fillStyle='rgba(74,82,112,0.8)';
  ctx.font='11px IBM Plex Mono,monospace'; ctx.textAlign='left';
  ctx.fillText('— superficie', W-130, 18);
  ctx.fillStyle='rgba(13,148,136,0.9)';
  ctx.fillText('— plano tangente', W-130, 34);
  ctx.fillStyle='rgba(180,83,9,0.9)';
  ctx.fillText('● punto de tangencia', W-130, 50);
}

