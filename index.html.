      2: '💪 Necesitas más práctica. Regresa a las secciones anteriores.',
      1: '🔄 Te recomendamos repasar toda la clase desde el inicio.',
      0: '🔄 No te preocupes — los conceptos llevan práctica. Vuelve al inicio.'
    };
    document.getElementById('score-msg').textContent = msgs[scores] || '';
    scoreEl.scrollIntoView({behavior:'smooth', block:'center'});
  }
}

